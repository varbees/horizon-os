# Gemini (server-side only; never expose to the browser). Key: https://ai.google.dev/gemini-api/docs/api-key
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Nvidia NIM APIs (for running Llama, DeepSeek, etc. via build.nvidia.com)
NVIDIA_NIM_API_KEY=
NVIDIA_NIM_MODEL=meta/llama-3.1-8b-instruct
NVIDIA_NIM_ENDPOINT=https://integrate.api.nvidia.com/v1/chat/completions
NVIDIA_NIM_MODELS_ENDPOINT=https://integrate.api.nvidia.com/v1/models

# DeepSeek (same key Hermes uses — cheap workhorse for trivial action enrichment; first in provider order)
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_MODELS_ENDPOINT=https://api.deepseek.com/models
DEEPSEEK_CHAT_ENDPOINT=https://api.deepseek.com/chat/completions

# Optional future providers for Horizon action enrichment.
OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_MODELS_ENDPOINT=https://api.openai.com/v1/models
OPENAI_CHAT_ENDPOINT=https://api.openai.com/v1/chat/completions
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=
ANTHROPIC_VERSION=2023-06-01
ANTHROPIC_MODELS_ENDPOINT=https://api.anthropic.com/v1/models
ANTHROPIC_MESSAGES_ENDPOINT=https://api.anthropic.com/v1/messages

# Jules (async repo work). Create an API key in the Jules web app Settings (jules.google.com, max 3).
# Auth header is X-Goog-Api-Key. The repo must be connected via the Jules GitHub app to appear as a source.
JULES_API_KEY=
HORIZON_API_PORT=8791
HORIZON_VAULT_PATH=
HORIZON_PROJECT_INDEX=
HORIZON_PROJECT_SWEEP_ROOTS=
HORIZON_PROJECT_SWEEP_INTERVAL_MINUTES=60
