# Gemini (server-side only; never expose to the browser). Key: https://ai.google.dev/gemini-api/docs/api-key
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
# Jules (async repo work). Create an API key in the Jules web app Settings (jules.google.com, max 3).
# Auth header is X-Goog-Api-Key. The repo must be connected via the Jules GitHub app to appear as a source.
JULES_API_KEY=
HORIZON_API_PORT=8787
HORIZON_VAULT_PATH=
HORIZON_PROJECT_INDEX=
HORIZON_PROJECT_SWEEP_ROOTS=
HORIZON_PROJECT_SWEEP_INTERVAL_MINUTES=60
